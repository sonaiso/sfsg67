{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gold Corpus Sample",
  "description": "Schema for a single annotated Arabic sample in the gold corpus.",
  "type": "object",
  "required": ["id", "text", "annotations", "annotator"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^gold_[0-9]{3}$"
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "annotations": {
      "type": "object",
      "required": ["tokens"],
      "properties": {
        "tokens": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "normalized", "start", "end"],
            "properties": {
              "text": { "type": "string" },
              "normalized": { "type": "string" },
              "start": { "type": "integer", "minimum": 0 },
              "end": { "type": "integer", "minimum": 0 },
              "root": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 3,
                "maxItems": 4
              },
              "pattern": { "type": "string" },
              "event_type": {
                "type": "string",
                "enum": ["ACTION", "STATE", "PROCESS", "ACHIEVEMENT", "ACCOMPLISHMENT"]
              }
            }
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["head", "dep", "role"],
            "properties": {
              "head": { "type": "integer", "minimum": 0 },
              "dep": { "type": "integer", "minimum": 0 },
              "role": { "type": "string" }
            }
          }
        },
        "classification": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["خبر", "إنشاء"] },
            "strength": { "type": "string", "enum": ["قطعي", "معلّق"] }
          }
        }
      }
    },
    "annotator": {
      "type": "string",
      "enum": ["manual", "semi-auto"]
    },
    "notes": {
      "type": "string"
    }
  }
}
